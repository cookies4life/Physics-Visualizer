"""
Physics Visualizer
------------------
Entry point. Shows the main menu and routes the user's choice
to the right category module.
"""

from menu import show_menu
import classical_mechanics
import quantum_mechanics
import relativistic_mechanics
import statistical_mechanics


def main():
    while True:
        choice = show_menu()

        if choice == "1":
            classical_mechanics.start()
        elif choice == "2":
            quantum_mechanics.start()
        elif choice == "3":
            relativistic_mechanics.start()
        elif choice == "4":
            statistical_mechanics.start()
        elif choice == "0":
            print("Goodbye!")
            break
        else:
            print("Invalid choice, try again.\n")


if __name__ == "__main__":
    main()